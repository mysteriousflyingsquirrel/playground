{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/shell-policy.mjs",
        "timeout": 15
      }
    ],
    "subagentStart": [
      {
        "command": "node .cursor/hooks/subagent-start-review-gate.mjs",
        "timeout": 8
      }
    ],
    "subagentStop": [
      {
        "command": "node .cursor/hooks/subagent-stop-review-loop.mjs",
        "timeout": 15,
        "loop_limit": 5
      }
    ]
  }
}
